# Redis
REDIS_URL=redis://redis:6379/0

# Backend
SECRET_KEY=change-me-in-production
ENVIRONMENT=development

# Rate limiting (requests per second per endpoint)
ENDPOINT_RATE_LIMIT=2
# Max concurrent endpoint queries per search job
MAX_CONCURRENT_QUERIES=50
# Timeout per endpoint query (seconds)
ENDPOINT_TIMEOUT=10

# SMART on FHIR
# Public client ID registered with FHIR endpoints (use "drls-public" for open/sandbox endpoints)
SMART_CLIENT_ID=drls-public
# Must match redirect_uri registered with each endpoint
SMART_REDIRECT_URI=http://localhost:3000/auth/callback

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Set to "false" to disable demo mode and use live SMART OAuth flows
NEXT_PUBLIC_DEMO_MODE=true
# Production Vercel URL — set this in Railway so CORS allows your frontend (e.g. https://your-app.vercel.app)
FRONTEND_URL=
